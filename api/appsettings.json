{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=excel_dataset_manager;Username=app;Password=app_password"
  },
  "Jwt": {
    "Issuer": "ExcelDatasetManager",
    "Audience": "ExcelDatasetManagerFrontend",
    "Key": ""
  },
  "Encryption": {
    "MasterKey": ""
  },
  "Oauth": {
    "PublicUrl": "http://localhost"
  },
  "Cors": {
    "AllowedOrigins": ["*"]
  },
  "Storage": {
    "RootPath": "storage"
  },
  "Upload": {
    "MaxFileSizeMb": 100
  },
  "Query": {
    "DefaultLimit": 100,
    "HardMaxRows": 1000,
    "TimeoutSeconds": 30,
    "MemoryLimit": "1GB",
    "SafeMaxTokens": 32000,
    "HardMaxTokens": 512000,
    "PreviewRows": 10,
    "TokenEstimationCharsPerToken": 4,
    "ConfirmationTTLMinutes": 15
  },
  "ExternalQuery": {
    "TimeoutSeconds": 30,
    "MaxConcurrentPerConnection": 3,
    "ConcurrencyWaitMs": 200,
    "MaxTablesPerDataset": 50
  },
  "Dashboard": {
    "MaxRowsPerWidget": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.RateLimiting": "Warning"
    }
  },
  "AllowedHosts": "*"
}
