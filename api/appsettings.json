{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=excel_dataset_manager;Username=app;Password=app_password"
  },
  "Jwt": {
    "Issuer": "ExcelDatasetManager",
    "Audience": "ExcelDatasetManagerFrontend",
    "Key": ""
  },
  "Cors": {
    "AllowedOrigins": ["*"]
  },
  "Storage": {
    "RootPath": "storage"
  },
  "Upload": {
    "MaxFileSizeMb": 100
  },
  "Query": {
    "DefaultLimit": 100,
    "HardMaxRows": 1000,
    "TimeoutSeconds": 30,
    "MemoryLimit": "1GB"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.RateLimiting": "Warning"
    }
  },
  "AllowedHosts": "*"
}
