<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Giữ nguyên response JSON/error từ API/MCP, không để IIS thay body lỗi -->
    <httpErrors existingResponse="PassThrough" />

    <security>
      <requestFiltering>
        <!-- MAX_UPLOAD_MB=100 => 100 * 1024 * 1024 = 104857600 bytes -->
        <requestLimits maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>

    <rewrite>
      <rules>
        <clear />

        <!-- MCP endpoint: https://domain/mcp -> Docker bridge local port 5848 -->
        <rule name="ReverseProxyToMcpBridge" stopProcessing="true">
          <match url="^mcp(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:5848/{R:0}" />
        </rule>

        <!-- Web/API: các route còn lại -> ASP.NET API local port 5847 -->
        <rule name="ReverseProxyToApi" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:5847/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>