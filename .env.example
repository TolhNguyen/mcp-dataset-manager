# ============================================================
# Public domain / Caddy reverse proxy
# ============================================================
# Use your real domain in production, e.g. data.your-company.com.
# Caddy will automatically request HTTPS certificates for real public domains.
EDM_DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443

# ============================================================
# Database
# ============================================================
POSTGRES_DB=excel_dataset_manager
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_PORT=5432

# ============================================================
# API
# ============================================================
API_PORT=5847
ASPNETCORE_ENVIRONMENT=Production

# REQUIRED. Must be at least 32 characters. Random hex from `openssl rand -hex 32` works well.
# The app refuses to start if this is missing, too short, or starts with "CHANGE_ME".
JWT_KEY=

# REQUIRED. >= 32 chars. Encrypts stored external-database credentials (AES-256-GCM).
# `openssl rand -hex 32`. The app refuses to start without it.
EDM_ENCRYPTION_KEY=

# REQUIRED for MCP OAuth. Your public base URL — must be https in production.
#   e.g. https://data.your-company.com
EDM_PUBLIC_URL=http://localhost

JWT_ISSUER=ExcelDatasetManager
JWT_AUDIENCE=ExcelDatasetManagerFrontend

# Comma-separated list of allowed origins, or "*" to allow any.
CORS_ALLOWED_ORIGIN=*

# ============================================================
# Remote MCP bridge
# ============================================================
# Add a connector in Claude at:  https://<EDM_DOMAIN>/mcp
# Claude runs the OAuth flow — the user logs in and clicks Allow (no token to paste).
MCP_RATE_LIMIT_PER_MINUTE=180

# ============================================================
# Upload limits
# ============================================================
MAX_UPLOAD_MB=100

# ============================================================
# Query engine
# ============================================================
QUERY_DEFAULT_LIMIT=100
QUERY_HARD_MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30
QUERY_MEMORY_LIMIT=1GB
QUERY_MAX_DATASETS_PER_QUERY=3
QUERY_SAFE_MAX_TOKENS=32000
QUERY_HARD_MAX_TOKENS=512000

# ============================================================
# External live databases (MySQL / MSSQL / PostgreSQL / BigQuery)
# ============================================================
EXTERNAL_QUERY_TIMEOUT_SECONDS=30
EXTERNAL_MAX_CONCURRENT=3
EXTERNAL_MAX_TABLES=50

# ============================================================
# Dashboards
# ============================================================
DASHBOARD_MAX_ROWS_PER_WIDGET=1000
